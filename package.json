{
  "name": "floorist",
  "version": "0.2.1",
  "description": "Dependency-free web component for drawing and editing real-world floor plans — multi-floor buildings, tables, chairs, doors, windows, A/C, custom images — with attachable actions, doors/windows that snap to walls, and a custom JSON format.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./component": {
      "types": "./dist/component/floor-plan.d.ts",
      "default": "./dist/component/floor-plan.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run compile && npm run test:cov && node ./scripts/coverage-readme.mjs",
    "compile": "tsc",
    "watch": "tsc --watch",
    "dev": "npm run compile && node ./scripts/serve.js",
    "serve": "node ./scripts/serve.js",
    "test": "npm run compile && node --test 'test/*.test.mjs'",
    "test:cov": "node --test --experimental-test-coverage --test-coverage-include='dist/**/*.js' --test-coverage-exclude='dist/component/**' --test-coverage-exclude='dist/render/renderer.js' --test-coverage-exclude='dist/render/shapes.js' --test-coverage-exclude='dist/editor/controller.js' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage.lcov 'test/*.test.mjs'",
    "coverage": "npm run compile && npm run test:cov && node ./scripts/coverage-readme.mjs",
    "clean": "rm -rf dist coverage.lcov",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "floor-plan",
    "floorplan",
    "building",
    "storey",
    "web-component",
    "canvas",
    "editor",
    "drag-and-drop",
    "seating",
    "layout",
    "typescript",
    "no-dependencies"
  ],
  "author": "aimtune <hamzaagareng@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AimTune/floorist.git"
  },
  "homepage": "https://github.com/AimTune/floorist#readme",
  "bugs": {
    "url": "https://github.com/AimTune/floorist/issues"
  },
  "sideEffects": [
    "./dist/component/floor-plan.js"
  ],
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
